{
  "name": "@vabster/editor",
  "version": "0.0.4",
  "description": "A lightweight WYSIWYG rich text editor for React built on the native contenteditable API — no heavy dependencies.",
  "keywords": [
    "wysiwyg",
    "editor",
    "rich-text",
    "rich-text-editor",
    "react",
    "contenteditable",
    "text-editor",
    "html-editor",
    "toolbar"
  ],
  "homepage": "https://vaahe.github.io/wysiwyg-editor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaahe/wysiwyg-editor.git",
    "directory": "packages/editor"
  },
  "bugs": {
    "url": "https://github.com/vaahe/wysiwyg-editor/issues"
  },
  "license": "ISC",
  "author": "vabster",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": {
      "types": "./dist/styles.css.d.ts",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "build": "tsup && pnpm build:css",
    "build:css": "postcss styles/index.css -o dist/styles.css && echo \"declare const styles: never;\\nexport default styles;\" > dist/styles.css.d.ts",
    "dev": "concurrently -k \"tsup --watch\" \"pnpm dev:css\"",
    "dev:css": "postcss styles/index.css -o dist/styles.css --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.61.0"
  }
}
