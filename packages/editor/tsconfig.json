{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "rootDir": "src",
    "outDir": "dist",
    "composite": false,
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo",
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "*"
      ],
      "@components": [
        "components/*"
      ],
      "@core": [
        "core/*"
      ],
      "@lib": [
        "lib/*"
      ],
      "@utils": [
        "utils/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}